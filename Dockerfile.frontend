# AlgoTutor frontend — tiny static file server.
# Serves docs/ via the existing Node serve.mjs on port 8080.
FROM node:22-alpine

WORKDIR /app

# Copy the static site + the serve script. No npm deps — serve.mjs uses Node stdlib only.
COPY docs ./docs

EXPOSE 8080
ENV PORT=8080
CMD ["node", "docs/serve.mjs"]
