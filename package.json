{
  "name": "algotutor",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "node docs/run-tests.mjs",
    "build": "node docs/build-dataset.mjs",
    "serve": "node docs/serve.mjs",
    "backend:start": "node --experimental-sqlite backend/server.mjs",
    "backend:build": "docker compose build",
    "up": "node -e \"require('fs').mkdirSync('data',{recursive:true})\" && docker compose up -d && node -e \"console.log('\\n  AlgoTutor is running:\\n    Frontend  http://localhost:8080\\n    Backend   http://localhost:9090/api/health\\n    Database  ./data/algotutor.db\\n')\"",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "backend:up": "docker compose up -d algotutor-backend",
    "backend:down": "docker compose down",
    "backend:logs": "docker compose logs -f algotutor-backend",
    "e2e": "node -e \"process.env.ALGOTUTOR_E2E='1';require('child_process').execSync('docker compose up -d',{stdio:'inherit',env:{...process.env,ALGOTUTOR_E2E:'1'}})\" && playwright test",
    "e2e:up": "node -e \"require('child_process').execSync('docker compose up -d',{stdio:'inherit',env:{...process.env,ALGOTUTOR_E2E:'1'}})\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
