          },
          {
            "name": "k",
            "type": "int"
          }
        ],
        "returns": "int"
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function findCheapestPrice(n: number, flights: number[][], src: number, dst: number, k: number): number {\n  let dist = new Array(n).fill(Infinity);\n  dist[src] = 0;\n  for (let i = 0; i <= k; i++) {\n    const next = dist.slice();\n    for (const [u,v,w] of flights) {\n      if (dist[u] === Infinity) continue;\n      if (dist[u] + w < next[v]) next[v] = dist[u] + w;\n    }\n    dist = next;\n  }\n  return dist[dst] === Infinity ? -1 : dist[dst];\n}"
  },
