  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function ladderLength(beginWord: string, endWord: string, wordList: string[]): number {\n  const dict = new Set(wordList);\n  if (!dict.has(endWord)) return 0;\n  const q: [string, number][] = [[beginWord, 1]];\n  dict.delete(beginWord);\n  while (q.length) {\n    const [w, d] = q.shift()!;\n    if (w === endWord) return d;\n    const arr = w.split(\"\");\n    for (let i = 0; i < arr.length; i++) {\n      const orig = arr[i];\n      for (let c = 97; c <= 122; c++) {\n        const ch = String.fromCharCode(c);\n        if (ch === orig) continue;\n        arr[i] = ch;\n        const nw = arr.join(\"\");\n        if (dict.has(nw)) { dict.delete(nw); q.push([nw, d+1]); }\n      }\n      arr[i] = orig;\n    }\n  }\n  return 0;\n}"
  },
