{
  "id": "find-all-anagrams-in-a-string",
  "leetcode_number": 438,
  "title": "Find All Anagrams in a String",
  "difficulty": "Medium",
  "categories": [
    "String",
    "Hash Table",
    "Sliding Window"
  ],
  "sources": [
    "LeetCode Top Interview 150"
  ],
  "prompt": "Given two strings s and p, return an array of every starting index in s where a substring of length p.length is an anagram of p. Indices may be returned in any order, but this dataset expects them in increasing order (the natural left-to-right scan).",
  "constraints": [
    "1 <= s.length, p.length <= 3 * 1e4",
    "lowercase English letters"
  ],
  "hints": [
    "Slide a window of length p.length across s, maintaining a 26-letter count.",
    "When the count matches p's count, record the starting index."
  ],
  "optimal": {
    "time": "O(n)",
    "space": "O(1) (26-array)",
    "approach": "Sliding window with character-count comparison."
  },
  "alternatives": [
    {
      "approach": "Sort each window",
      "time": "O(n m log m)",
      "space": "O(m)",
      "note": "TLE on long strings."
    }
  ],
  "pitfalls": [
    "Forgetting to decrement the outgoing character when sliding shifts off the left edge."
  ],
  "followups": [
    "Find all permutations / Permutation in String (LC 567)."
  ],
  "signature": {
    "fn": "findAnagrams",
    "params": [
      {
        "name": "s",
        "adapt": "identity"
      },
      {
        "name": "p",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity"
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function findAnagrams(s: string, p: string): number[] {\n  const out: number[] = [];\n  if (s.length < p.length) return out;\n  const need = new Array(26).fill(0);\n  const have = new Array(26).fill(0);\n  for (let i = 0; i < p.length; i++) {\n    need[p.charCodeAt(i) - 97]++;\n    have[s.charCodeAt(i) - 97]++;\n  }\n  const eq = () => { for (let i = 0; i < 26; i++) if (need[i] !== have[i]) return false; return true; };\n  if (eq()) out.push(0);\n  for (let i = p.length; i < s.length; i++) {\n    have[s.charCodeAt(i) - 97]++;\n    have[s.charCodeAt(i - p.length) - 97]--;\n    if (eq()) out.push(i - p.length + 1);\n  }\n  return out;\n}"
  },
  "tests": [
    {"name":"example-1","category":"example","input":{"s":"cbaebabacd","p":"abc"},"output":[0,6]},
    {"name":"example-2","category":"example","input":{"s":"abab","p":"ab"},"output":[0,1,2]},
    {"name":"p-longer","category":"edge","input":{"s":"aa","p":"bbb"},"output":[]},
    {"name":"no-anagrams","category":"edge","input":{"s":"abcdef","p":"gh"},"output":[]},
    {"name":"all-same-letter","category":"edge","input":{"s":"aaaaa","p":"aa"},"output":[0,1,2,3]},
    {"name":"stress-20k","category":"stress","input":{"s":"","p":"ptrqqdna"},"output":[]}
  ]
}
