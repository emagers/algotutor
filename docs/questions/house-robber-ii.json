  ],
  "prompt": "Same as House Robber, but the houses are arranged in a circle (the first and last houses are adjacent). Return the maximum amount you can rob.",
  "constraints": [
    "1 <= nums.length <= 100",
    "0 <= nums[i] <= 1000"
  ],
  "hints": [
    "Run linear House-Robber twice: once on nums[0..n-2], once on nums[1..n-1].",
    "Take the max — circular constraint reduces to two linear cases."
  ],
  "optimal": {
    "time": "O(n)",
    "space": "O(1)",
    "approach": "Two linear DP runs over slices."
  },
  "alternatives": [],
  "pitfalls": [
