  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function rob(nums: number[]): number {\n  if (nums.length === 1) return nums[0];\n  const lin = (arr: number[]) => {\n    let p = 0, c = 0;\n    for (const x of arr) { const n = Math.max(c, p + x); p = c; c = n; }\n    return c;\n  };\n  return Math.max(lin(nums.slice(0, -1)), lin(nums.slice(1)));\n}"
  },
