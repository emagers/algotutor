{
  "id": "add-binary",
  "leetcode_number": 67,
  "title": "Add Binary",
  "difficulty": "Easy",
  "categories": [
    "Math",
    "String",
    "Bit Manipulation"
  ],
  "sources": [
    "LeetCode Top Interview 150"
  ],
  "prompt": "Given two binary strings a and b, return their sum as a binary string. Inputs may be very long (up to ~10^4 bits), so do not convert directly to a fixed-width number.",
  "constraints": [
    "1 <= a.length, b.length <= 1e4",
    "characters are '0' or '1'",
    "no leading zeros except for '0' itself"
  ],
  "hints": [
    "Walk both strings from the right, tracking a carry.",
    "Don't forget to flush a final carry into a leading '1'."
  ],
  "optimal": {
    "time": "O(max(m, n))",
    "space": "O(max(m, n))",
    "approach": "Two-pointer right-to-left addition with carry."
  },
  "alternatives": [
    {
      "approach": "BigInt addition",
      "time": "O(n)",
      "space": "O(n)",
      "note": "Cheating in interviews; use only as a sanity check."
    }
  ],
  "pitfalls": [
    "Stopping the loop while a non-zero carry remains."
  ],
  "followups": [
    "Add Strings (LC 415)."
  ],
  "signature": {
    "fn": "addBinary",
    "params": [
      {
        "name": "a",
        "adapt": "identity"
      },
      {
        "name": "b",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity"
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function addBinary(a: string, b: string): string {\n  let i = a.length - 1, j = b.length - 1, c = 0, out = \"\";\n  while (i >= 0 || j >= 0 || c) {\n    const x = i >= 0 ? a.charCodeAt(i--) - 48 : 0;\n    const y = j >= 0 ? b.charCodeAt(j--) - 48 : 0;\n    const s = x + y + c;\n    out = (s & 1) + out;\n    c = s >> 1;\n  }\n  return out;\n}"
  },
  "tests": [
    {"name":"example-11+1","category":"example","input":{"a":"11","b":"1"},"output":"100"},
    {"name":"example-1010+1011","category":"example","input":{"a":"1010","b":"1011"},"output":"10101"},
    {"name":"zero+zero","category":"edge","input":{"a":"0","b":"0"},"output":"0"},
    {"name":"long-carry-chain","category":"edge","input":{"a":"1111","b":"1"},"output":"10000"},
    {"name":"different-lengths","category":"edge","input":{"a":"1","b":"111"},"output":"1000"},
    {"name":"stress-1000bit","category":"stress","input":{"a":"","b":""},"output":""}
  ]
}
