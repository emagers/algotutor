  "prompt": "Given an integer n, return the number of prime numbers strictly less than n.",
  "constraints": [
    "0 <= n <= 5 * 1e6"
  ],
  "hints": [
    "Sieve of Eratosthenes — mark composites in O(n log log n).",
    "Start crossing out from i*i (smaller multiples are already marked)."
  ],
  "optimal": {
    "time": "O(n log log n)",
    "space": "O(n)",
    "approach": "Sieve of Eratosthenes."
  },
  "alternatives": [
    {
      "approach": "Trial division up to sqrt(n)",
      "time": "O(n sqrt n / log n)",
      "space": "O(1)"
    }
  ],
  "pitfalls": [
    "Off-by-one — count strictly less than n, not <= n."
  ],
  "followups": [
    "Linear sieve (Euler) for prime listing."
  ],
  "signature": {
    "fn": "countPrimes",
    "params": [
      {
        "name": "n",
