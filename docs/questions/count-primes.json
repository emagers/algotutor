  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function countPrimes(n: number): number {\n  if (n <= 2) return 0;\n  const sieve = new Uint8Array(n);\n  let c = 0;\n  for (let i = 2; i < n; i++) {\n    if (!sieve[i]) {\n      c++;\n      for (let j = i * i; j < n; j += i) sieve[j] = 1;\n    }\n  }\n  return c;\n}"
  },
