  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function uniquePaths(m: number, n: number): number {\n  const dp = new Array(n).fill(1);\n  for (let i = 1; i < m; i++) for (let j = 1; j < n; j++) dp[j] += dp[j - 1];\n  return dp[n - 1];\n}"
  },
