    {"name":"example-2","category":"example","input":{"root":[1,null,3]},"output":[1,3]},
    {"name":"edge-empty","category":"edge","input":{"root":[]},"output":[]},
    {"name":"edge-single","category":"edge","input":{"root":[9]},"output":[9]},
    {"name":"edge-leftskew-only","category":"edge","input":{"root":[1,null,2,null,3,null,4,null,5]},"output":[1,2,3,4,5]},
    {"name":"edge-rightskew-only","category":"edge","input":{"root":[1,null,2,null,3,null,4,null,5]},"output":[1,2,3,4,5]},
    {"name":"edge-mixed-shorter-right","category":"edge","input":{"root":[1,2,3,4,null,null,null,5]},"note":"Deepest visible from right is the leftmost descendant in level 4.","output":[1,3,4,5]},
    {"name":"stress-balanced-100","category":"stress","input":{"root":[50,25,75,12,37,62,88,6,18,31,43,56,68,81,94,3,9,15,21,28,34,40,46,53,59,65,71,78,84,91,97,1,4,7,10,13,16,19,23,26,29,32,35,38,41,44,48,51,54,57,60,63,66,69,73,76,79,82,86,89,92,95,99,null,2,null,5,null,8,null,11,null,14,null,17,null,20,22,24,null,27,null,30,null,33,null,36,null,39,null,42,null,45,47,49,null,52,null,55,null,58,null,61,null,64,null,67,null,70,72,74,null,77,null,80,null,83,85,87,null,90,null,93,null,96,98,100]},"output":[50,75,88,94,97,99,100]}
  ]
}
