    {"name":"edge-no-permutation","category":"edge","input":{"s1":"hello","s2":"ooolleoooleh"},"output":false},
    {"name":"edge-single-char-found","category":"edge","input":{"s1":"a","s2":"abc"},"output":true},
    {"name":"edge-single-char-missing","category":"edge","input":{"s1":"z","s2":"abc"},"output":false},
    {"name":"edge-end-of-s2","category":"edge","input":{"s1":"abc","s2":"xxxxxxbca"},"output":true},
