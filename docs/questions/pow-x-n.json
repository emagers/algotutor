  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function myPow(x: number, n: number): number {\n  if (n === 0) return 1;\n  let N = n;\n  if (N < 0) { x = 1 / x; N = -N; }\n  let r = 1, base = x;\n  while (N > 0) {\n    if (N & 1) r *= base;\n    base *= base;\n    N = Math.floor(N / 2);\n  }\n  return r;\n}"
  },
