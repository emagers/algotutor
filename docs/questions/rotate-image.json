            "name": "matrix",
            "type": "&mut Vec<Vec<i32>>"
          }
        ],
        "returns": "()"
      },
      "go": {
        "params": [
          {
            "name": "matrix",
            "type": "[][]int"
          }
        ],
        "returns": ""
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function rotate(matrix: number[][]): void {\n  const n = matrix.length;\n  for (let i = 0; i < n; i++)\n    for (let j = i + 1; j < n; j++)\n      [matrix[i][j], matrix[j][i]] = [matrix[j][i], matrix[i][j]];\n  for (const row of matrix) row.reverse();\n}"
  },
