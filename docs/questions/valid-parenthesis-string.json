    {"name":"single-close","category":"edge","input":{"s":")"},"output":false},
    {"name":"deep-nesting","category":"edge","input":{"s":"((((**))))"},"output":true},
    {"name":"stress-100","category":"stress","input":{"s":"(*()())**())(*(***))*(((()*(**))*)(((*(*))*(()((((()*))*())())())***)((((*((*((**())()()()***((**(()"},"output":false}
  ]
