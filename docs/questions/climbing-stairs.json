  "prompt": "You are climbing a staircase. It takes n steps to reach the top. Each time you can climb either 1 or 2 steps. In how many distinct ways can you climb to the top?",
  "constraints": [
    "1 <= n <= 45"
  ],
  "hints": [
    "f(n) = f(n-1) + f(n-2) — Fibonacci.",
    "Iterate with two rolling variables."
  ],
  "optimal": {
    "time": "O(n)",
    "space": "O(1)",
    "approach": "Bottom-up DP (Fibonacci)."
  },
  "alternatives": [
    {
      "approach": "Recursion + memo",
      "time": "O(n)",
      "space": "O(n)"
    }
  ],
  "pitfalls": [
    "Stack overflow on naive recursion at n=45 (no memo)."
  ],
  "followups": [
    "k steps allowed at a time."
  ],
  "signature": {
    "fn": "climbStairs",
    "params": [
      {
        "name": "n",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity",
    "kind": "function",
    "judgeSource": "return",
    "codeTypes": {
      "rust": {
        "params": [
          {
            "name": "n",
            "type": "i32"
          }
        ],
        "returns": "i32"
      },
      "go": {
        "params": [
          {
            "name": "n",
            "type": "int"
          }
        ],
        "returns": "int"
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function climbStairs(n: number): number {\n  if (n <= 2) return n;\n  let a = 1, b = 2;\n  for (let i = 3; i <= n; i++) { const c = a + b; a = b; b = c; }\n  return b;\n}"
  },
