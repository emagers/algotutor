  "comparison": "setOfArrays",
  "solution": {
    "language": "TypeScript",
    "code": "function combinationSum(candidates: number[], target: number): number[][] {\n  const arr = candidates.slice().sort((a, b) => a - b);\n  const out: number[][] = [];\n  const cur: number[] = [];\n  const dfs = (start: number, rem: number): void => {\n    if (rem === 0) { out.push(cur.slice()); return; }\n    for (let i = start; i < arr.length; i++) {\n      if (arr[i] > rem) break;\n      cur.push(arr[i]);\n      dfs(i, rem - arr[i]);\n      cur.pop();\n    }\n  };\n  dfs(0, target);\n  return out;\n}"
  },
