    {"name":"example-2-empty","category":"example","input":{"grid":[[0,0,0],[0,0,0]]},"output":0},
    {"name":"edge-single-cell-1","category":"edge","input":{"grid":[[1]]},"output":1},
    {"name":"edge-single-cell-0","category":"edge","input":{"grid":[[0]]},"output":0},
