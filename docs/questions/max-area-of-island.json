{
  "id": "max-area-of-island",
  "leetcode_number": 695,
  "title": "Max Area of Island",
  "difficulty": "Medium",
  "categories": [
    "Matrix",
    "DFS",
    "BFS"
  ],
  "sources": [
    "Grind 75"
  ],
  "prompt": "Given an m x n binary matrix where 1 represents land and 0 represents water, return the maximum area (in cells) of any 4-connected island. The matrix may be modified in place during traversal.",
  "constraints": [
    "1 <= m, n <= 50",
    "grid[i][j] in {0, 1}"
  ],
  "hints": [
    "DFS from each unvisited land cell, sinking it (set to 0) and counting cells visited.",
    "Iterative DFS or BFS works equally well."
  ],
  "optimal": {
    "time": "O(m*n)",
    "space": "O(m*n)",
    "approach": "DFS sinking with running max."
  },
  "alternatives": [
    {
      "approach": "BFS with visited set",
      "time": "O(m*n)",
      "space": "O(m*n)"
    }
  ],
  "pitfalls": [
    "Counting diagonal neighbors by mistake.",
    "Recursion depth on a 50×50 all-land board may exceed default stack on some platforms."
  ],
  "followups": [
    "Number of distinct island shapes (LC 711)."
  ],
  "signature": {
    "fn": "maxAreaOfIsland",
    "params": [
      {
        "name": "grid",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity"
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function maxAreaOfIsland(grid: number[][]): number {\n  const m = grid.length, n = grid[0].length;\n  let best = 0;\n  const dfs = (i: number, j: number): number => {\n    if (i<0||j<0||i>=m||j>=n||grid[i][j]!==1) return 0;\n    grid[i][j] = 0;\n    return 1 + dfs(i+1,j) + dfs(i-1,j) + dfs(i,j+1) + dfs(i,j-1);\n  };\n  for (let i = 0; i < m; i++) for (let j = 0; j < n; j++) if (grid[i][j] === 1) {\n    const a = dfs(i,j);\n    if (a > best) best = a;\n  }\n  return best;\n}"
  },
