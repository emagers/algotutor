{
  "id": "insert-interval",
  "number": 72,
  "title": "Insert Interval",
  "difficulty": "Medium",
  "categories": [
    "Array",
    "Intervals"
  ],
  "prompt": "You are given an array of non-overlapping intervals sorted by start time and a new interval. Insert the new interval into the list (merging overlaps as needed). Return the resulting list of non-overlapping intervals sorted by start time.",
  "constraints": [
    "0 <= intervals.length <= 1e4",
    "intervals[i].length == 2",
    "intervals[i][0] <= intervals[i][1]",
    "intervals are sorted by start"
  ],
  "hints": [
    "Three phases: append all that end before newInterval starts; merge all that overlap; append the rest.",
    "Track running start = min, end = max while merging."
  ],
  "optimal": {
    "time": "O(n)",
    "space": "O(n)",
    "approach": "Single linear scan with merge phase."
  },
  "alternatives": [
    {
      "approach": "Concatenate & merge",
      "time": "O(n log n)",
      "space": "O(n)"
    }
  ],
  "pitfalls": [
    "Boundary touch (intervals[i][1] == newInterval[0]) merges, not separates."
  ],
  "followups": [],
  "signature": {
    "fn": "insertInterval",
    "params": [
      {
        "name": "intervals",
        "adapt": "identity"
      },
      {
        "name": "newInterval",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity",
    "kind": "function",
    "judgeSource": "return",
    "codeTypes": {
      "rust": {
        "params": [
          {
            "name": "intervals",
            "type": "Vec<Vec<i32>>"
          },
          {
            "name": "newInterval",
            "type": "Vec<i32>"
          }
        ],
        "returns": "Vec<Vec<i32>>"
      },
      "go": {
        "params": [
          {
            "name": "intervals",
            "type": "[][]int"
          },
          {
            "name": "newInterval",
            "type": "[]int"
          }
        ],
        "returns": "[][]int"
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function insert(intervals: number[][], newInterval: number[]): number[][] {\n  const out: number[][] = [];\n  let [s, e] = newInterval;\n  let i = 0;\n  while (i < intervals.length && intervals[i][1] < s) out.push(intervals[i++]);\n  while (i < intervals.length && intervals[i][0] <= e) {\n    s = Math.min(s, intervals[i][0]);\n    e = Math.max(e, intervals[i][1]);\n    i++;\n  }\n  out.push([s, e]);\n  while (i < intervals.length) out.push(intervals[i++]);\n  return out;\n}"
  },
