            "type": "*ListNode"
          },
          {
            "name": "l2",
            "type": "*ListNode"
          }
        ],
        "returns": "*ListNode"
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function addTwoNumbers(l1: ListNode | null, l2: ListNode | null): ListNode | null {\n  const dummy = new ListNode();\n  let cur: ListNode = dummy, carry = 0;\n  while (l1 || l2 || carry) {\n    const a = l1 ? l1.val : 0;\n    const b = l2 ? l2.val : 0;\n    const sum = a + b + carry;\n    carry = Math.floor(sum / 10);\n    cur.next = new ListNode(sum % 10);\n    cur = cur.next;\n    if (l1) l1 = l1.next;\n    if (l2) l2 = l2.next;\n  }\n  return dummy.next;\n}"
  },
