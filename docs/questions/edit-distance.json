  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function minDistance(a: string, b: string): number {\n  const m = a.length, n = b.length;\n  const dp = new Array(n + 1);\n  for (let j = 0; j <= n; j++) dp[j] = j;\n  for (let i = 1; i <= m; i++) {\n    let prev = dp[0];\n    dp[0] = i;\n    for (let j = 1; j <= n; j++) {\n      const tmp = dp[j];\n      if (a[i - 1] === b[j - 1]) dp[j] = prev;\n      else dp[j] = 1 + Math.min(prev, dp[j], dp[j - 1]);\n      prev = tmp;\n    }\n  }\n  return dp[n];\n}"
  },
