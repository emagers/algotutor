    {"name":"max","category":"edge","input":{"num":3999},"output":"MMMCMXCIX"},
    {"name":"round-thousand","category":"edge","input":{"num":2000},"output":"MM"},
    {"name":"subtractive","category":"edge","input":{"num":444},"output":"CDXLIV"}
  ]
}
