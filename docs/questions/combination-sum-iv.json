  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function combinationSum4(nums: number[], target: number): number {\n  const dp = new Array(target + 1).fill(0);\n  dp[0] = 1;\n  for (let s = 1; s <= target; s++) for (const x of nums) if (s >= x) dp[s] += dp[s - x];\n  return dp[target];\n}"
  },
