{
  "id": "unique-paths-ii",
  "leetcode_number": 63,
  "title": "Unique Paths II",
  "difficulty": "Medium",
  "categories": [
    "Array",
    "Dynamic Programming",
    "Matrix"
  ],
  "sources": [
    "LeetCode Top Interview 150"
  ],
  "prompt": "Same as Unique Paths but obstacleGrid[i][j] == 1 marks a blocked cell. Return the number of unique paths from top-left to bottom-right.",
  "constraints": [
    "1 <= m, n <= 100",
    "obstacleGrid[i][j] is 0 or 1."
  ],
  "hints": [
    "Same DP — set dp[j]=0 when obstacleGrid[i][j]==1.",
    "Watch the start cell: if blocked, answer is 0."
  ],
  "optimal": {
    "time": "O(m*n)",
    "space": "O(n)",
    "approach": "Rolling 1D DP with obstacle zeroing."
  },
  "alternatives": [],
  "pitfalls": [
    "Initial cell may itself be an obstacle (return 0)."
  ],
  "followups": [],
  "signature": {
    "fn": "uniquePathsWithObstacles",
    "params": [
      {
        "name": "grid",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity"
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function uniquePathsWithObstacles(grid: number[][]): number {\n  const m = grid.length, n = grid[0].length;\n  const dp = new Array(n).fill(0);\n  dp[0] = grid[0][0] === 0 ? 1 : 0;\n  for (let i = 0; i < m; i++) {\n    for (let j = 0; j < n; j++) {\n      if (grid[i][j] === 1) dp[j] = 0;\n      else if (j > 0) dp[j] += dp[j - 1];\n    }\n  }\n  return dp[n - 1];\n}"
  },
  "tests": [
    {"name":"example-1","category":"example","input":{"grid":[[0,0,0],[0,1,0],[0,0,0]]},"output":2},
    {"name":"example-2","category":"example","input":{"grid":[[0,1],[0,0]]},"output":1},
    {"name":"start-blocked","category":"edge","input":{"grid":[[1,0],[0,0]]},"output":0},
    {"name":"end-blocked","category":"edge","input":{"grid":[[0,0],[0,1]]},"output":0},
    {"name":"single-clear","category":"edge","input":{"grid":[[0]]},"output":1},
    {"name":"single-blocked","category":"edge","input":{"grid":[[1]]},"output":0},
    {"name":"wall-row","category":"edge","input":{"grid":[[0,0,0],[1,1,1],[0,0,0]]},"output":0},
