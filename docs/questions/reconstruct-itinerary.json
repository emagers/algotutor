{
  "id": "reconstruct-itinerary",
  "leetcode_number": 332,
  "title": "Reconstruct Itinerary",
  "difficulty": "Hard",
  "categories": [
    "Graph",
    "DFS",
    "Eulerian Path"
  ],
  "sources": [
    "LeetCode Top Interview 150"
  ],
  "prompt": "Given a list of airline tickets [from, to], reconstruct the itinerary in order. The trip starts at \"JFK\" and uses every ticket exactly once. If multiple valid itineraries exist, return the one that is lexicographically smallest when read as a single concatenated list.",
  "constraints": [
    "1 <= tickets.length <= 300",
    "Airport codes are 3-letter uppercase strings.",
    "An itinerary is guaranteed to exist."
  ],
  "hints": [
    "It's an Eulerian path problem: visit every edge exactly once.",
    "Sort each adjacency list ascending; do DFS visiting smallest unused outgoing edge first.",
    "Hierholzer: when you can't go further, prepend the current node to the path."
  ],
  "optimal": {
    "time": "O(E log E)",
    "space": "O(E)",
    "approach": "Hierholzer's algorithm with sorted adjacency lists."
  },
  "alternatives": [
    {
      "approach": "Backtracking trying lexicographic order",
      "time": "Exponential worst case",
      "space": "O(E)"
    }
  ],
  "pitfalls": [
    "Returning the path in reverse (forgot to reverse the result).",
    "Re-using tickets — adjacency lists must be consumed."
  ],
  "followups": [
    "Eulerian circuit detection.",
    "Eulerian path on undirected graphs."
  ],
  "signature": {
    "fn": "findItinerary",
    "params": [
      {
        "name": "tickets",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity"
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function findItinerary(tickets: string[][]): string[] {\n  const adj = new Map<string, string[]>();\n  for (const [a,b] of tickets) {\n    if (!adj.has(a)) adj.set(a, []);\n    adj.get(a)!.push(b);\n  }\n  for (const arr of adj.values()) arr.sort();\n  const out: string[] = [];\n  const dfs = (u: string) => {\n    const arr = adj.get(u);\n    while (arr && arr.length) dfs(arr.shift()!);\n    out.push(u);\n  };\n  dfs(\"JFK\");\n  return out.reverse();\n}"
  },
  "tests": [
    {"name":"example-1","category":"example","input":{"tickets":[["MUC","LHR"],["JFK","MUC"],["SFO","SJC"],["LHR","SFO"]]},"output":["JFK","MUC","LHR","SFO","SJC"]},
    {"name":"example-2-multi-choice","category":"example","input":{"tickets":[["JFK","SFO"],["JFK","ATL"],["SFO","ATL"],["ATL","JFK"],["ATL","SFO"]]},"output":["JFK","ATL","JFK","SFO","ATL","SFO"]},
    {"name":"edge-single-ticket","category":"edge","input":{"tickets":[["JFK","ABC"]]},"output":["JFK","ABC"]},
    {"name":"edge-cycle-back-to-jfk","category":"edge","input":{"tickets":[["JFK","KUL"],["JFK","NRT"],["NRT","JFK"]]},"output":["JFK","NRT","JFK","KUL"]},
    {"name":"edge-must-finish-distant","category":"edge","input":{"tickets":[["JFK","A"],["A","B"],["B","C"],["C","A"],["A","JFK"]]},"output":["JFK","A","B","C","A","JFK"]},
