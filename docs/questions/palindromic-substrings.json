    {"name":"edge-two-diff","category":"edge","input":{"s":"bc"},"output":2},
    {"name":"edge-all-same-10","category":"edge","input":{"s":"aaaaaaaaaa"},"output":55},
    {"name":"edge-no-pal-beyond-1","category":"edge","input":{"s":"abcdef"},"output":6},
    {"name":"edge-mix","category":"edge","input":{"s":"abacdfgdcaba"},"output":14},
