    {"name":"stress-1000-all-same","category":"stress","input":{"s":""},"note":"All n*(n+1)/2 substrings are palindromes.","output":500500},
    {"name":"stress-1000-alt","category":"stress","input":{"s":""},"output":250500}
  ]
}
