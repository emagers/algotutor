  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function longestCommonSubsequence(a: string, b: string): number {\n  const m = a.length, n = b.length;\n  const dp = new Array(n + 1).fill(0);\n  for (let i = 1; i <= m; i++) {\n    let prev = 0;\n    for (let j = 1; j <= n; j++) {\n      const tmp = dp[j];\n      if (a[i - 1] === b[j - 1]) dp[j] = prev + 1;\n      else dp[j] = Math.max(dp[j], dp[j - 1]);\n      prev = tmp;\n    }\n  }\n  return dp[n];\n}"
  },
