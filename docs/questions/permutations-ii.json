{
  "id": "permutations-ii",
  "number": 139,
  "title": "Permutations II",
  "difficulty": "Medium",
  "categories": [
    "Array",
    "Backtracking"
  ],
  "prompt": "Given a collection of numbers nums that might contain duplicates, return all possible unique permutations.",
  "constraints": [
    "1 <= nums.length <= 8",
    "-10 <= nums[i] <= 10"
  ],
  "hints": [
    "Sort, then skip nums[i] if it equals nums[i-1] and nums[i-1] is not currently used (sibling-skip)."
  ],
  "optimal": {
    "time": "O(n * n!)",
    "space": "O(n)",
    "approach": "Sort + DFS with sibling-skip."
  },
  "alternatives": [],
  "pitfalls": [
    "Use `!used[i-1]` (not `used[i-1]`) — the rule fixes the relative order of equal elements."
  ],
  "followups": [],
  "signature": {
    "fn": "permuteUnique",
    "params": [
      {
        "name": "nums",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity",
    "kind": "function",
    "judgeSource": "return",
    "codeTypes": {
      "rust": {
        "params": [
          {
            "name": "nums",
            "type": "Vec<i32>"
          }
        ],
        "returns": "Vec<Vec<i32>>"
      },
      "go": {
        "params": [
          {
            "name": "nums",
            "type": "[]int"
          }
        ],
        "returns": "[][]int"
      }
    }
  },
  "comparison": "setOfArrays",
  "solution": {
    "language": "TypeScript",
    "code": "function permuteUnique(nums: number[]): number[][] {\n  nums = nums.slice().sort((a, b) => a - b);\n  const out: number[][] = [];\n  const cur: number[] = [];\n  const used = new Array(nums.length).fill(false);\n  const dfs = (): void => {\n    if (cur.length === nums.length) { out.push(cur.slice()); return; }\n    for (let i = 0; i < nums.length; i++) {\n      if (used[i]) continue;\n      if (i > 0 && nums[i] === nums[i - 1] && !used[i - 1]) continue;\n      used[i] = true; cur.push(nums[i]);\n      dfs();\n      cur.pop(); used[i] = false;\n    }\n  };\n  dfs();\n  return out;\n}"
  },
