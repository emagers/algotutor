{
  "id": "factorial-trailing-zeroes",
  "leetcode_number": 172,
  "title": "Factorial Trailing Zeroes",
  "difficulty": "Medium",
  "categories": [
    "Math"
  ],
  "sources": [
    "LeetCode Top Interview 150"
  ],
  "prompt": "Given an integer n, return the number of trailing zeroes in n! (n factorial).",
  "constraints": [
    "0 <= n <= 1e4"
  ],
  "hints": [
    "Each trailing zero is produced by a factor of 5 paired with a factor of 2.",
    "There are always more 2s than 5s in factorial — count multiples of 5.",
    "Don't forget multiples of 25, 125, ..."
  ],
  "optimal": {
    "time": "O(log5 n)",
    "space": "O(1)",
    "approach": "Sum of floor(n/5) + floor(n/25) + floor(n/125) + ..."
  },
  "alternatives": [
    {
      "approach": "Compute n! and count zeros",
      "time": "O(n)",
      "space": "O(n)",
      "note": "Overflows for large n in fixed-width."
    }
  ],
  "pitfalls": [
    "Using only floor(n/5) misses higher multiples — every multiple of 25 contributes an extra 5, etc."
  ],
  "followups": [
    "Find smallest n such that n! has exactly k trailing zeroes."
  ],
  "signature": {
    "fn": "trailingZeroes",
    "params": [
      {
        "name": "n",
        "adapt": "identity"
      }
    ],
    "returnAdapt": "identity",
    "kind": "function",
    "judgeSource": "return",
    "codeTypes": {
      "rust": {
        "params": [
          {
            "name": "n",
            "type": "i32"
          }
        ],
        "returns": "i32"
      },
      "go": {
        "params": [
          {
            "name": "n",
            "type": "int"
          }
        ],
        "returns": "int"
      }
    }
  },
  "comparison": "exact",
  "solution": {
    "language": "TypeScript",
    "code": "function trailingZeroes(n: number): number {\n  let c = 0;\n  while (n > 0) { n = Math.floor(n / 5); c += n; }\n  return c;\n}"
  },
  "tests": [
    {"name":"example-3","category":"example","input":{"n":3},"output":0},
    {"name":"example-5","category":"example","input":{"n":5},"output":1},
    {"name":"example-0","category":"example","input":{"n":0},"output":0},
    {"name":"n-25","category":"edge","input":{"n":25},"output":6},
    {"name":"n-125","category":"edge","input":{"n":125},"output":31},
    {"name":"n-10000","category":"stress","input":{"n":10000},"output":2499}
  ]
}
